{
  "expo": {
    "name": "OutdoorAdvisor",
    "slug": "OutdoorAdvisor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "OutdoorAdvisor needs your location to show air quality and weather for your area.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.ahmadadnanone.OutdoorAdvisor"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "icon": "./assets/icon.png"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-background-task",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "OutdoorAdvisor reads your steps, walking distance, and activity energy to time smart outdoor walk suggestions.",
          "NSHealthUpdateUsageDescription": "OutdoorAdvisor does not write health data, but iOS requires a Health access description for this integration.",
          "background": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "OutdoorAdvisor needs your location to show air quality and weather for your area."
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0b8b92b0-0722-4ab1-b4c4-34df3ba8e956"
      }
    },
    "owner": "ahmadadnanone"
  }
}
